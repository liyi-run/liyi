// liyi v0.1 spec file
{
  "version": "0.1",
  "source": "crates/liyi-cli/src/tui_approve.rs",
  "specs": [
    {
      "item": "Highlighter",
      "reviewed": true,
      "intent": "Hold shared syntax-highlighting resources (SyntaxSet and Theme) that are initialised once per TUI session and reused across all candidates to avoid repeated loading.",
      "source_span": [
        22,
        25
      ],
      "tree_path": "struct::Highlighter",
      "source_hash": "sha256t:651f1e27d096d2f23ab0f407acb9988ed1118c235800c8b32e0956d50595166a",
      "source_anchor": "struct Highlighter {"
    },
    {
      "item": "ApproveTui",
      "reviewed": true,
      "intent": "Hold TUI state for the approval workflow: a reference to the candidates slice, a parallel decisions vector (initialized to Skip), the current item index, a vertical scroll offset for the source pane, a quit flag, and a Highlighter for syntax colouring. On construction, loads syntect default syntaxes and the base16-eighties.dark theme and sets initial scroll to centre on the first candidate's span. Provides methods to advance (decide), go back (both auto-centre scroll on the new span), and check completion.",
      "source_span": [
        28,
        36
      ],
      "tree_path": "struct::ApproveTui",
      "source_hash": "sha256t:a3aaf1fc8bab7bef7d05dcd8903de12aa678a1bde1eeba45ddce01983b7ae966",
      "source_anchor": "struct ApproveTui<'a> {"
    },
    {
      "item": "run_tui",
      "reviewed": true,
      "intent": "Enter raw mode and alternate screen on stderr, run the main event loop (draw frame, read key, dispatch action), then restore terminal state. Returns a Vec<Decision> parallel to candidates. Must cleanly restore terminal even on early quit. Keys: y=approve, n=reject, e=edit (leaves TUI for $EDITOR, approves with edited intent or cancels on empty result), s/Enter=skip, a=approve-all-remaining, b/Left=go-back, Right=go-forward, j/Down and k/Up=scroll source, PgUp/PgDn=page-scroll source, q/Esc=quit. The e key suspends raw mode and alternate screen, spawns the editor, then re-enters both, rebuilding the terminal.",
      "source_span": [
        169,
        247
      ],
      "tree_path": "fn::run_tui",
      "source_hash": "sha256t:b5d2b469ff3c37403da5902d5187f4c6bd2675abe2eefb7cde0875b052d5d6e2",
      "source_anchor": "pub fn run_tui(candidates: &[ApprovalCandidate]) -> io::Result<Vec<Decision>> {"
    },
    {
      "item": "draw",
      "reviewed": true,
      "intent": "Compose the full-screen layout into five vertical regions (header, intent pane, source pane, progress gauge, keybinding footer) and delegate rendering to the per-region draw functions, passing the shared Highlighter to draw_source.",
      "source_span": [
        249,
        271
      ],
      "tree_path": "fn::draw",
      "source_hash": "sha256t:2d5de9dfd08ce60b1df40e5488a9e527055025afe98fee47c3b057b79b404ad4",
      "source_anchor": "fn draw(f: &mut ratatui::Frame, app: &ApproveTui) {"
    },
    {
      "item": "draw_intent",
      "reviewed": true,
      "intent": "Render the intent pane with one of three modes based on prev_intent: (1) 'Intent (new)' — no prior approval, show current intent in white; (2) 'Intent (unchanged from last approval)' — previous matches current, show with reassuring title; (3) 'Intent (changed)' — show previous and current intents with word-level diff highlighting via diff_spans: removed words in white-on-red, inserted words in white-on-green, unchanged text in base red/green. Uses push_span_lines for newline-aware rendering. Handles =doc sentinel for all branches.",
      "source_span": [
        356,
        449
      ],
      "tree_path": "fn::draw_intent",
      "source_hash": "sha256t:cda79be63c0fb3e2ff96301ed56e017cf585386242d4bee29dbddbc3ec5cb691",
      "source_anchor": "fn draw_intent(f: &mut ratatui::Frame, area: Rect, candidate: &ApprovalCandidate) {"
    },
    {
      "item": "go_forward",
      "reviewed": true,
      "intent": "Advance to the next candidate without changing its decision. If already on the last candidate, do nothing. Resets scroll to centre on the new candidate's span.",
      "source_span": [
        86,
        91
      ],
      "tree_path": "impl::ApproveTui<'a>::fn::go_forward",
      "source_hash": "sha256t:ba432e4daf3750616b1508cb2800eab09841b75a55ceb3eb5da4398bb9a46745",
      "source_anchor": "    fn go_forward(&mut self) {"
    },
    {
      "item": "file_highlight_enabled",
      "reviewed": true,
      "intent": "Return true if the source file is small enough for syntax highlighting (at most MAX_HIGHLIGHT_LINES lines). Files exceeding this threshold fall back to plain text to avoid UI lag.",
      "source_span": [
        466,
        468
      ],
      "tree_path": "fn::file_highlight_enabled",
      "source_hash": "sha256t:cfb2581067ccece845cd39e6edb2eacb5ee99fa8d2ffe3f1c8fbab7e96c3d159",
      "source_anchor": "fn file_highlight_enabled(candidate: &ApprovalCandidate) -> bool {"
    },
    {
      "item": "line_highlight_enabled",
      "reviewed": true,
      "intent": "Return true if a single line is short enough for syntax highlighting (at most MAX_LINE_LEN bytes). Longer lines fall back to plain text to prevent the regex engine from stalling.",
      "source_span": [
        472,
        474
      ],
      "tree_path": "fn::line_highlight_enabled",
      "source_hash": "sha256t:fda70f9cb32977604fcf8ba20bf16348d61c4447e270d30ddaba859eaa8eba8d",
      "source_anchor": "fn line_highlight_enabled(line: &str) -> bool {"
    },
    {
      "item": "draw_source",
      "reviewed": true,
      "intent": "Render the source code pane with syntect-based syntax highlighting, gated by file_highlight_enabled and line_highlight_enabled. Resolves a syntax definition from the source file extension (falling back to plain text), runs HighlightLines over each eligible line, and maps syntect styles to ratatui Span styles. Span lines receive a subtle background highlight (SPAN_BG) to distinguish them from surrounding file content. Prepends a line-number gutter. Supports vertical scrolling.",
      "source_span": [
        476,
        570
      ],
      "tree_path": "fn::draw_source",
      "source_hash": "sha256t:ddd044516e2725481f30bb2f70008933076c589ef4b5cc21d567de3ae279e321",
      "source_anchor": "fn draw_source("
    },
    {
      "item": "edit_intent_in_editor",
      "reviewed": true,
      "intent": "Open $VISUAL / $EDITOR / vi on a tempfile pre-populated with the current intent text followed by comment lines containing the item name, source location, and previous intent (if any). Comment lines start with '#' and are stripped on read-back. Returns Some(edited_text) if non-empty after stripping, None if empty or editor exited with error. Deletes the tempfile after reading.",
      "source_span": [
        101,
        165
      ],
      "tree_path": "fn::edit_intent_in_editor",
      "source_hash": "sha256t:ccd97544ce0adbee4e805e4e81d23b1b1fa7a6c21f34b50f439f6e437b2c927d",
      "source_anchor": "fn edit_intent_in_editor(candidate: &ApprovalCandidate) -> Option<String> {"
    },
    {
      "item": "diff_spans",
      "reviewed": true,
      "intent": "Produce styled ratatui Spans for one side of a word-level diff between old and new text. Uses similar::TextDiff with Patience algorithm. Equal segments get base_style; segments matching the selected side (Delete for previous, Insert for current) get highlight_style; the other side's changes are omitted.",
      "source_span": [
        301,
        326
      ],
      "tree_path": "fn::diff_spans",
