    {
      "item": "Language",
      "reviewed": true,
      "intent": "Enumerate all built-in tree-sitter languages for tree_path operations: Bash, Dart, Rust, Ruby, Python, Go, JavaScript, TypeScript, TSX, C, C++, Java, C#, PHP, Objective-C, Kotlin, Swift, Zig, TOML, JSON, and YAML. Each variant maps to a static LanguageConfig via config().",
      "source_span": [
        178,
        200
      ],
      "tree_path": "enum.Language",
      "source_hash": "sha256:22ac6ffee8cb31c56dc49788f70b5ddf5a7e7e3d40fd1ba96053073b5c797416",
      "source_anchor": "pub enum Language {"
    },
    {
      "item": "node_name",
      "reviewed": true,
      "intent": "Extract the user-visible name of an AST node via the language's LanguageConfig. Checks the custom_name callback first (for complex patterns like Go receiver encoding). Falls back to name_overrides for special cases (e.g., impl_item uses type field). Otherwise reads the standard name field. Returns Cow::Owned for constructed names, Cow::Borrowed for field-extracted names.",
      "source_span": [
        115,
        135
      ],
      "tree_path": "impl.LanguageConfig::fn.node_name",
      "source_hash": "sha256:c311d8a17fab52814d95f71fd4346ce81ec87abcdd0514575e94f6934471f2e2",
      "source_anchor": "    fn node_name<'a>(&self, node: &Node<'a>, source: &'a str) -> Option<Cow<'a, str>> {"
    },
    {
      "item": "resolve_tree_path",
      "reviewed": true,
      "intent": "Parse a tree_path string via the nom grammar (parser::TreePath::parse). When the parsed path contains an injection marker (//lang), delegates to resolve_with_injection for sub-parsing. Otherwise, collect Pairs into (kind, name, optional index) triples and walk the tree-sitter AST via resolve_segments to resolve the path to a 1-indexed inclusive [start, end] line span. Returns None on empty/malformed input, parse failure, or when no matching AST node is found.",
      "source_span": [
        349,
        388
      ],
      "tree_path": "fn.resolve_tree_path",
      "source_hash": "sha256:8833ea54e59f99c50eae9ac1d12cb9081b7a356780f00c6a5a397e081cd7fedd",
      "source_anchor": "pub fn resolve_tree_path(source: &str, tree_path: &str, lang: Language) -> Option<[usize; 2]> {",
      "related": {
        "content-offset-correctness": "sha256:bb335adf95f08bc33400de939be514ef2bfdcdb0180fd261a33f2e8653c8e37a",
        "injection-pair-attachment": "sha256:1acfbdf7d5a6272774346b2951f7692a016b02542b100b412b11bb948d58ec97"
      }
    },
    {
      "item": "SiblingScanResult",
      "reviewed": true,
      "intent": "Hold the result of a hash-based sibling scan: the 1-indexed inclusive span of the matched sibling element and the updated tree_path with the corrected array index.",
      "source_span": [
        495,
        500
      ],
      "tree_path": "struct.SiblingScanResult",
      "source_hash": "sha256:16f08b111123e54dffb3cbdba88814476eea4ff857aaf1941bebd85157e8180c",
      "source_anchor": "pub struct SiblingScanResult {"
    },
    {
      "item": "resolve_tree_path_sibling_scan",
      "reviewed": true,
      "intent": "Fallback for indexed array elements whose positional resolution produces a hash mismatch. Parse the tree_path into Pairs, find the last pair with an index, resolve the parent array container, iterate all named children (resolving any suffix pairs within each), hash each candidate's span, and return the unique match. Returns None when no pair has an index, the parent array cannot be resolved, or zero/multiple elements match (ambiguous). Must never silently pick a wrong element — exactly-one-match invariant enforced.",
      "source_span": [
        514,
        618
      ],
      "tree_path": "fn.resolve_tree_path_sibling_scan",
      "source_hash": "sha256:072feb4d7d0c496e47ccb3b17eb41af6bfe7bc25807fe5839d916c496799f5df",
      "source_anchor": "pub fn resolve_tree_path_sibling_scan(",
      "related": {
        "sibling-scan-recovery": "sha256:9f3c1ac03a88188f97c3ea850988d5f55f7a2f78c34b28104f47da67ba0f64e7"
      }
    },
    {
      "item": "resolve_segments",
      "reviewed": true,
      "intent": "Walk tree-sitter children of the given parent to find nodes matching each path segment in order. Accepts segments as &[PathPair] (kind, name, optional index) triples. For segments with an index, delegate to resolve_indexed_child for positional array access. For single-segment paths, return the matching child directly. For multi-segment paths, descend into the first matching child via resolve_in_body for subsequent segments. When a child's kind is in transparent_kinds, recurse into it to find item nodes nested inside wrapper containers (e.g., Dart class_member, YAML block_node/block_mapping).",
      "source_span": [
        628,
        669
      ],
      "tree_path": "fn.resolve_segments",
      "source_hash": "sha256:d701a59918c33182385f2ddd6d6bbbbef485d0fe2f27d798ca9bb1357ab21292",
      "source_anchor": "fn resolve_segments<'a>("
    },
    {
      "item": "resolve_in_body",
      "reviewed": true,
      "intent": "Find subsequent path segments inside an item's body. Delegates to config.find_body to locate the body node, then to resolve_segments for recursive matching. Accepts segments as &[PathPair] (kind, name, optional index) triples.",
      "source_span": [
        714,
