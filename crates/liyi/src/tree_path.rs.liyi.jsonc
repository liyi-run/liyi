      "source_anchor": "/// Resolve a `tree_path` to a source span `[start_line, end_line]` (1-indexed,"
    },
    {
      "item": "resolve_segments",
      "reviewed": false,
      "intent": "Walk tree-sitter children of the given parent to find nodes matching each path segment in order. For single-segment paths, return the matching child directly. For multi-segment paths, descend into the first matching child via resolve_in_body for subsequent segments.",
      "source_span": [
        148,
        176
      ],
      "tree_path": "fn::resolve_segments",
      "source_hash": "sha256:cb4227e128b6b2b7cf3766e0f8c492e21692cbcf44b5a4b95addffb34ad87451",
      "source_anchor": "fn resolve_segments<'a>("
    },
    {
      "item": "resolve_in_body",
      "reviewed": false,
      "intent": "Find subsequent path segments inside an item's body or declaration_list. Try the 'body' field first (mod, fn), then fall back to looking for a declaration_list child (impl, trait). Delegate to resolve_segments for the recursive match.",
      "source_span": [
        179,
        196
      ],
      "tree_path": "fn::resolve_in_body",
      "source_hash": "sha256:470ba72b9ef02207aa4219a62a756cea99fcaea5c6c96d58081531d74ef3ee30",
