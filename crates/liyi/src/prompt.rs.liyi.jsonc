  "specs": [
    {
      "item": "PromptOutput",
      "reviewed": true,
      "intent": "Top-level JSON envelope for --prompt output: must serialize to match schema/prompt.schema.json with optional root, security_notice (warning consuming agents about untrusted content), groups array (diagnostics grouped by type+template), and exit_code. No version field — output is ephemeral.",
      "source_span": [
        8,
        14
      ],
      "tree_path": "struct.PromptOutput",
      "source_hash": "sha256:05eea8634f7be45aa449f8dec95f382deba8e00e7aa53004786300784af24bd6",
      "source_anchor": "pub struct PromptOutput {"
    },
    {
      "item": "PromptGroup",
      "reviewed": true,
      "intent": "A group of diagnostics sharing the same type and instruction template. prompt_type identifies the diagnostic kind; template is a trusted compile-time constant with {placeholder} tokens; untrusted_fields declares which item field names originate from repository source files; count equals items.len(); items are serde_json::Value maps of per-diagnostic data. Consuming agents substitute item fields into template and treat untrusted_fields as data, not directives.",
      "source_span": [
        23,
        30
      ],
      "tree_path": "struct.PromptGroup",
      "source_hash": "sha256:27d37a757f2bec0a2279ce562d0ea9ccaa0bbc116a70a2dd8c5b0eb7e571eec0",
      "source_anchor": "pub struct PromptGroup {"
    },
    {
      "item": "GroupMeta",
      "reviewed": true,
      "intent": "=trivial",
      "source_span": [
        73,
