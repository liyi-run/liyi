    },
    {
      "item": "write_sidecar",
      "reviewed": false,
      "intent": "Serialize a SidecarFile to pretty-printed JSON prefixed with a '// liyi v0.1 spec file' header comment and a trailing newline.",
      "source_span": [
        129,
