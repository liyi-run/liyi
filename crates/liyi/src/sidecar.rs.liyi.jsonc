  "specs": [
    {
      "item": "SidecarFile",
      "reviewed": false,
      "intent": "Model the top-level .liyi.jsonc file with version, source path, and a list of specs. Enforce deny_unknown_fields to reject extraneous keys during deserialization.",
      "source_span": [
        4,
        11
      ],
      "tree_path": "struct::SidecarFile",
      "source_hash": "sha256:e832dbb2f978f79be6b0135630e2f5bbd314753f4ba09eee25a476ad4c1a622b",
      "source_anchor": "/// Top-level `.liyi.jsonc` file representation"
    },
    {
      "item": "Spec",
      "reviewed": false,
      "intent": "Discriminated union of ItemSpec and RequirementSpec, using untagged serde deserialization so the variant is inferred from the presence of 'item' vs 'requirement' keys.",
      "source_span": [
        13,
        19
      ],
      "tree_path": "enum::Spec",
      "source_hash": "sha256:a3a7434250cc317950588f0ea7c5873d0c92103f84c8f2e435c3103d42d7326a",
      "source_anchor": "/// Represents either an item or a requirement spec"
    },
    {
      "item": "ItemSpec",
      "reviewed": false,
      "intent": "Model a code-item spec entry with item name, intent string, source_span, and optional fields (reviewed, source_hash, source_anchor, confidence, related). Enforce deny_unknown_fields and skip serializing None optionals.",
      "source_span": [
        21,
        45
      ],
      "source_hash": "sha256:261e0cf01af970f1f2f14ef4cd3a0f101e04e700218bcda7eadeac0949e851bc",
      "source_anchor": "/// Details of a code item (function, struct, etc.)"
    },
    {
      "item": "RequirementSpec",
      "reviewed": false,
      "intent": "Model a requirement spec entry with requirement name, source_span, and optional source_hash/source_anchor. Enforce deny_unknown_fields and skip serializing None optionals.",
      "source_span": [
        47,
        60
      ],
      "source_hash": "sha256:80fb1f6f3b1f13c07d70d2cae39a895914c96f8e3ae18a908c4f0cb5ac6eafc0",
      "source_anchor": "    pub related: Option<HashMap<String, Option<String>>>,"
    },
    {
      "item": "strip_jsonc_comments",
      "reviewed": false,
      "intent": "Remove // line comments and /* block comments from JSONC input while respecting JSON string boundaries and backslash escapes. Preserve newlines from line comments so downstream line numbers remain meaningful.",
      "source_span": [
        68,
        120
      ],
      "tree_path": "fn::strip_jsonc_comments",
      "source_hash": "sha256:9dc96d8d82dab62dc9874ea22649619671cb75068f9866011ddb7b09e24de922",
      "source_anchor": "/// Strip `//` line comments and `/* */` block comments from JSONC input,"
    },
    {
      "item": "parse_sidecar",
      "reviewed": false,
      "intent": "Parse a .liyi.jsonc string by stripping JSONC comments then deserializing into a SidecarFile. Return a human-readable error on parse failure.",
      "source_span": [
        122,
        127
      ],
      "tree_path": "fn::parse_sidecar",
