{
  "version": "0.1",
  "source": "crates/liyi/src/check.rs",
  "specs": [
    {
      "item": "RequirementRecord",
      "reviewed": true,
      "intent": "Hold the file path, line number, sidecar hash, and freshly computed source hash of a discovered @liyi:requirement. The computed_hash enables cascading staleness detection in a single check pass without needing --fix first.",
      "source_span": [
        21,
        28
      ],
      "tree_path": "struct.RequirementRecord",
      "source_hash": "sha256:4a938b349644222f5387b748f99750302de0d71c7c0e528025bff26d2533497b",
      "source_anchor": "struct RequirementRecord {"
    },
    {
      "item": "ItemCheckCtx",
      "reviewed": true,
      "intent": "Bundle the shared read-only item-check context: the current source file path, source text, scanned source markers, and the active --fix mode. This lets check-sidecar logic thread one context object through item hash checking helpers instead of re-passing each field separately.",
      "source_span": [
        30,
        35
      ],
      "tree_path": "struct.ItemCheckCtx",
      "source_hash": "sha256:5bf334d473c3ae421d430680d21cdae7f803bded1ad3fd8eafa9d45b906a2424",
      "source_anchor": "struct ItemCheckCtx<'a> {"
    },
    {
      "item": "run_check",
      "reviewed": false,
      "intent": "Orchestrate the two-pass check by delegating to helpers: pass 1 calls discover_requirements, compute_requirement_hashes, collect_source_related_refs, enrich_requirements_from_sidecars to build the global requirement registry; pass 2 calls check_sidecar for each entry. Post-pass calls emit_untracked_requirements (which auto-creates sidecar entries when --fix is active), emit_unreferenced_requirements, detect_requirement_cycles, and emit_cycle_diagnostics. Return sorted diagnostics and the appropriate exit code based on CheckFlags.",
      "source_span": [
        47,
        120
      ],
      "tree_path": "fn.run_check",
      "source_hash": "sha256:88948f92628a77b7d083d374eef32f9e3c9a4b65f35c6b9e8b8f9f55ce0ec06f",
      "source_anchor": "pub fn run_check(",
      "related": {
        "cycle-detection": "sha256:e8af30a5974fcccf038c0d07eb98c279b57c9671dad032123424aa041d1262ec",
        "requirement-discovery-global": "sha256:8fdcf5001d02d4622dd7c8a5bd89090119e35cd2aedf7b8d9d7243d5f4cff359",
        "requirement-name-uniqueness": "sha256:fc329b7eb4016b20e9baa89b14470f2953aa6bad5311aa5d4867702994d94f32"
      }
    },
