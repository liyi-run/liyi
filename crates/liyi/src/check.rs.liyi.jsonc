    {
      "item": "check_sidecar",
      "reviewed": true,
      "intent": "For a single sidecar entry: parse the sidecar, validate its version and source_hash format, verify the source file exists, then for each spec delegate to check_item_hash, check_review_status, check_trivial_ignore, check_related_edges (for items) or check_requirement_hash (for requirements, with marker-based span recovery first). When --fix is active, strip _hints from all item specs. Write the sidecar back if --fix produced modifications.",
      "source_span": [
        534,
        800
      ],
      "tree_path": "fn.check_sidecar",
