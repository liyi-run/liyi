      }
    },
    {
      "item": "collect_req_changed",
      "reviewed": false,
      "intent": "Collect ApprovalCandidates for each related requirement whose stored hash differs from the current requirement registry hash on an effectively reviewed item. Preserve the shared display context and include old/new requirement text for diff display. Return an empty list when the item is filtered out, not effectively reviewed, has no related edges, or all related hashes still match.",
      "source_span": [
        354,
        421
      ],
