      "source_anchor": "fn collect_unreviewed("
    },
    {
      "item": "collect_stale",
      "reviewed": false,
      "intent": "Return an ApprovalCandidate for an effectively reviewed item whose stored source_hash no longer matches the current span contents. Preserve the shared display context, capture current source text, and recover previous source text from Git history. Return None when the item is filtered out, not effectively reviewed, lacks a source_hash, or its hash still matches.",
      "source_span": [
        296,
        352
      ],
      "tree_path": "fn.collect_stale",
