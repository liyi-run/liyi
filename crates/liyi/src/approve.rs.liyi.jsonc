      "source_anchor": "fn build_requirement_registry(repo_root: &Path) -> HashMap<String, RequirementInfo> {"
    },
    {
      "item": "lookup_prev_requirement_text",
      "reviewed": false,
      "intent": "Recover the old text of a requirement by walking Git history, using the same two-pass strategy as lookup_prev_source (fast path with current span, slow path via sidecar history for pre-shift spans). Return None when no matching revision is found.",
      "source_span": [
        484,
        542
      ],
      "tree_path": "fn.lookup_prev_requirement_text",
