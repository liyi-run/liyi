      "source_anchor": "fn collect_req_changed("
    },
    {
      "item": "build_requirement_registry",
      "reviewed": true,
      "intent": "Build a global requirement registry by scanning all sidecars in the repo via discover(). For each RequirementSpec, reads the source file, computes a fresh hash from marker-delimited spans (falling back to sidecar span), and stores current text. Returns a HashMap mapping requirement name to RequirementInfo.",
      "source_span": [
        429,
        477
      ],
