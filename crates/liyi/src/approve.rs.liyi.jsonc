    {
      "item": "collect_unreviewed",
      "reviewed": false,
      "intent": "Return an ApprovalCandidate for an item that is still unreviewed after applying the optional item filter and source @liyi:intent override check. Populate the shared display context, span offsets, and previous reviewed intent from Git history. Return None when the item is filtered out or effectively reviewed.",
      "source_span": [
        252,
        294
      ],
      "tree_path": "fn.collect_unreviewed",
