    {
      "requirement": "fix-never-modifies-human-fields",
      "source_span": [
        1442,
        1444
      ],
      "source_hash": "sha256:607df81587523fe5a12ddb1b5d4ef92aaed48c07811581d4c9fe40a8d6fe0b6a",
