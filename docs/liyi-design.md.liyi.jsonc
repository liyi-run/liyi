    {
      "requirement": "requirement-discovery-global",
      "source_span": [
        1054,
        1056
      ],
      "source_hash": "sha256:c6a5b25878f52c9f835e31aa11a060af59e390e64f0730d153004a7993548c6f",
      "source_anchor": "```gitignore"
    },
    {
      "requirement": "liyi-check-exit-code",
      "source_span": [
        1177,
        1183
      ],
      "source_hash": "sha256:3c5e25f88155fb2751b7ff2b520cc60e1b6f0172c854077b54dab753e169f682",
      "source_anchor": "**Summary-first output.** The summary line is printed before the per-item diagnostics, so that in large projects the user sees the aggregate picture immediately — without scrolling past hundreds of lines. (When the output is short enough, this also serves as a final line for quick scanning.)"
    },
